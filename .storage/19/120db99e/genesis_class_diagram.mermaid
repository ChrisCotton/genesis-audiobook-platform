        +String definition
        +List~String~ examples
        +List~Media~ mediaItems
        +FlashcardStatus status
        +DateTime nextReviewDate
        +createCard()
        +review()
        +updateSchedule()
    }

    class Conversation {
        +String id
        +String bookId
        +List~ConversationMessage~ messages
        +DateTime createdAt
        +DateTime updatedAt
        +startConversation()
        +sendMessage()
        +analyzeContext()
    }

    class ConversationMessage {
        +String id
        +String conversationId
        +String content
        +MessageSenderEnum sender
        +DateTime timestamp
        +List~TextReference~ referencedContent
        +generateResponse()
        +addReference()
    }

    class BookClub {
        +String id
        +String name
        +String description
        +List~Book~ books
        +List~User~ members
        +List~Discussion~ discussions
        +List~Meeting~ meetings
        +User createdBy
        +DateTime createdAt
        +DateTime updatedAt
        +createClub()
        +inviteMember()
        +scheduleMeeting()
        +startDiscussion()
    }

    class Discussion {
        +String id
