    }

    class SearchEngine {
        +indexContent()
        +performFullTextSearch()
        +implementSemanticSearch()
        +rankResults()
        +filterByFacets()
    }

    % Relationships
    User "1" -- "1" UserProfile : has
    User "1" -- "1" UserPreferences : has
    User "1" -- "*" Book : owns
    User "1" -- "*" Annotation : creates
    User "1" -- "*" BookClub : participates in
    User "1" -- "*" Discussion : authors

    Book "1" -- "1" BookContent : contains
    Book "1" -- "1" AudioNarration : has
    Book "1" -- "1" LearningMaterials : generates

    BookContent "1" -- "*" BookSection : divided into
    BookSection "1" -- "1" AudioSegment : synchronized with

    LearningMaterials "1" -- "*" Quiz : contains
    LearningMaterials "1" -- "*" MindMap : contains
    LearningMaterials "1" -- "*" Flashcard : contains

    Quiz "1" -- "*" QuizQuestion : consists of

    MindMap "1" -- "*" MindMapNode : has

    BookClub "1" -- "*" Discussion : hosts
    BookClub "1" -- "*" Meeting : schedules

    DocumentProcessor -- Book : processes
    TextAnalysisEngine -- BookContent : analyzes
    VoiceSynthesizer -- AudioNarration : generates
    ConversationalAI -- Conversation : powers
    LearningContentGenerator -- LearningMaterials : creates
    LanguageLearningEngine -- Book : enhances

    SubscriptionManager -- User : manages access for
    CreatorPlatform -- User : empowers
    EnterpriseManager -- BookClub : organizes

    AuthenticationService -- User : authenticates
    SearchEngine -- Book : indexes