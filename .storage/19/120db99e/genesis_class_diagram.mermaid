classDiagram
    class User {
        +String id
        +String username
        +String email
        +UserProfile profile
        +Library library
        +LearningStats stats
        +UserPreferences preferences
        +DateTime createdAt
        +DateTime updatedAt
        +registerAccount()
        +updateProfile()
        +manageSubscription()
        +getProgress()
    }

    class UserProfile {
        +String displayName
        +String avatar
        +String bio
        +LearningStyleEnum learningStyle
        +List~Language~ languages
        +List~String~ expertiseAreas
        +PrivacySettings privacySettings
        +updateLearningStyle()
        +setPrivacyPreferences()
    }

    class UserPreferences {
        +ThemeEnum theme
        +String fontFamily
        +Int fontSize
        +Float lineSpacing
        +String preferredVoice
        +Float playbackSpeed
        +Boolean autoSync
        +NotificationSettings notificationSettings
        +updateDisplaySettings()
        +updatePlaybackSettings()
    }

    class Book {
        +String id
        +String title
        +String author
        +String coverImage
        +String description
        +BookMetadata metadata
        +BookFormatEnum format
        +BookContent content
        +DateTime createdAt
        +DateTime updatedAt
        +AudioNarration audioNarration
        +processBook()
        +generateAudio()
        +createLearningMaterials()
    }

    class BookContent {
        +List~BookSection~ sections
        +Int totalPages
        +Int wordCount
        +Int readingTime
        +ComplexityScore complexity
        +extractContent()
        +analyzeSections()
        +calculateReadingMetrics()
    }

    class BookSection {
        +String id
        +String title
        +String content
        +List~Image~ images
        +List~Table~ tables
        +List~Footnote~ footnotes
        +AudioSegment audioSegment
        +getTextContent()
        +getAudioSegment()
        +getSynchronizationPoints()
    }

    class AudioNarration {
        +String id
        +String bookId
        +VoiceType voice
        +Float duration
        +List~AudioSegment~ segments
        +DateTime createdAt
        +generateAudio()
        +streamAudio()
        +getSegmentByPosition()
    }

    class AudioSegment {
        +String id
        +String narrationId
        +String sectionId
        +Float startTime
        +Float endTime
        +String audioUrl
        +List~SyncMarker~ syncMarkers
        +play()
        +pause()
        +seekToPosition()
        +getTextSync()
    }

    class Annotation {
        +String id
        +String bookId
        +String sectionId
        +User user
        +String content
        +AnnotationTypeEnum annotationType
        +TextPosition position
        +DateTime createdAt
        +DateTime updatedAt
        +Boolean isShared
        +List~User~ sharedWith
        +createAnnotation()
        +updateContent()
        +shareWith()
        +delete()
    }

    class LearningMaterials {
        +List~Quiz~ quizzes
        +List~Flashcard~ flashcards
        +List~MindMap~ mindMaps
        +List~Summary~ summaries
        +List~Discussion~ discussions
        +generateQuiz()
        +createFlashcards()
        +buildMindMap()
        +generateSummary()
    }

    class Quiz {
        +String id
        +String title
        +List~QuizQuestion~ questions
        +DifficultyEnum difficulty
        +List~QuizCompletion~ completions
        +DateTime createdAt
        +generateQuestions()
        +evaluate()
        +adaptDifficulty()
    }

    class QuizQuestion {
        +String id
        +String quizId
        +String questionText
        +List~String~ options
        +Int correctOptionIndex
        +String explanation
        +checkAnswer()
        +provideHint()
    }

    class MindMap {
        +String id
        +String title
        +String centralConcept
        +List~MindMapNode~ nodes
        +List~MindMapEdge~ edges
        +DateTime createdAt
        +DateTime updatedAt
        +generateFromText()
        +addNode()
        +connectNodes()
        +exportMap()
    }

    class MindMapNode {
        +String id
        +String mindMapId
        +String label
        +NodeType type
        +Position position
        +String textReference
        +updateLabel()
        +movePosition()
    }

    class Flashcard {
        +String id
