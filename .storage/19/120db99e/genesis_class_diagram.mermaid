        +String content
        +User author
        +List~Comment~ comments
        +String bookId
        +String bookClubId
        +DateTime createdAt
        +DateTime updatedAt
        +postDiscussion()
        +addComment()
        +pinDiscussion()
    }

    class Meeting {
