        +DateTime startTime
        +DateTime endTime
        +String bookClubId
        +List~User~ attendees
        +String videoConferenceLink
        +List~Resource~ resources
        +scheduleMeeting()
        +joinMeeting()
        +addResources()
    }

    class DocumentProcessor {
        +supportedFormats
        +convertFormat()
        +extractText()
        +preserveStructure()
        +processImages()
        +handleOCR()
    }

